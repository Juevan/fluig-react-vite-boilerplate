# Variáveis de Ambiente para Desenvolvimento Local (Vite)
# Renomeie este arquivo para ".env.local" para que o Vite o leia.
# O arquivo ".env.local" já está no .gitignore, então suas senhas não subirão para o repositório.

# URL base do seu servidor Fluig (sem os caminhos do portal, apenas domínio e porta)
FLUIG_URL=http://127.0.0.1:8080

# Usuário e senha para injetar na chamada (autenticação Basic local)
# ATENÇÃO: Nunca suba o .env.local no Git!
FLUIG_USER=admin
FLUIG_PASS=adm

# --- SIMULAÇÕES DO MODO DE DESENVOLVIMENTO (VITE) ---
# Altere para "dark" para simular o fundo preto nativo do Fluig
VITE_FLUIG_THEME=dark

# Altere para o sufixo do idioma desejado: pt_BR, en_US ou es
VITE_FLUIG_LANG=pt_BR

# --- SEGURANÇA E BUILD ---
# Altere para "true" para desativar a ofuscação e minificação durante o build (útil para depuração).
DISABLE_SECURITY=false
